generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  phone          String?
  phoneNormalized String?        @db.VarChar(15)
  password       String
  role           Role            @default(EMPLOYEE)
  isActive       Boolean         @default(true)
  department     String?
  jobTitle       String?
  profilePhoto   String?
  preferences    Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspaceId    String?
  departmentId   String?
  breakStartedAt    DateTime?
  onlineStatus      OnlineStatus    @default(OFFLINE)
  lastSeen          DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  managerId      String?
  manager        User?           @relation("ManagerEmployees", fields: [managerId], references: [id])
  employees      User[]          @relation("ManagerEmployees")
  activities       Activity[]
  attendances      Attendance[]
  leads            Lead[]
  whatsappMessages WhatsAppMessage[]
  whatsappCampaigns WhatsAppCampaign[]
  whatsappAutoReplies WhatsAppAutoReply[]
  taskComments   TaskComment[]
  leaves         Leave[]
  leaveApprovals LeaveApproval[] @relation("ApproverLeaves")
  sessions       Session[]
  tasks          Task[]
  invoices       Invoice[]       @relation("CreatedInvoices")
  createdDeals   Deal[]          @relation("CreatedDeals")
  assignedDeals  Deal[]          @relation("AssignedDeals")
  sentEmails     EmailLog[]      @relation("SentEmails")
  emailTemplates EmailTemplate[]
  departmentRel  Department?     @relation(fields: [departmentId], references: [id])
  workspace      Workspace?      @relation(fields: [workspaceId], references: [id])
  statusLogs     UserStatusLog[]
  assignmentHistoriesAsEmployee  AssignmentHistory[] @relation("HistoryEmployee")
  assignmentHistoriesAsPrevious  AssignmentHistory[] @relation("HistoryPrevEmployee")
  employeeProfile    EmployeeProfile?
  notesAuthored      ManagerNote[] @relation("NoteAuthor")
  notesReceived      ManagerNote[] @relation("NoteSubject")
  importJobs         ImportJob[]
  assistantRequestLogs AssistantRequestLog[]

  @@index([phoneNormalized])
  @@index([managerId])
}

model EmployeeProfile {
  id                   String             @id @default(uuid())
  employeeId           String             @unique
  employee             User               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  availabilityStatus   AvailabilityStatus @default(ONLINE)
  maxDailyLeads        Int                @default(20)
  currentLeadLoad      Int                @default(0)
  lastAssignedAt       DateTime?
  responseSpeed        Float              @default(1.0)
  // Derived from sub-scores via calculatePerformanceScore()
  performanceScore     Float              @default(0.5)
  // Sub-score components (0-1 each)
  leadEffectiveness    Float              @default(0.5)
  responseQuality      Float              @default(0.5)
  followupDiscipline   Float              @default(0.5)
  attendanceReliability Float             @default(0.5)
  isAcceptingLeads     Boolean            @default(true)
  updatedAt            DateTime           @updatedAt

  @@index([availabilityStatus])
  @@index([isAcceptingLeads])
}

model UserStatusLog {
  id        String       @id @default(uuid())
  userId    String
  status    OnlineStatus
  note      String?
  changedAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
}

model Lead {
  id              String      @id @default(uuid())
  name            String
  email           String?
  phone           String?
  phoneNormalized String?     @db.VarChar(15)
  source          LeadSource
  enquiryType     EnquiryType?
  status          LeadStatus  @default(NEW)
  assignedToId    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  score            Int         @default(0)
  scoreExplanation Json?
  category        String?
  firstResponseAt  DateTime?
  nextFollowUpAt   DateTime?
  workspaceId      String?
  isSearchLead    Boolean     @default(false)
  linkedinUrl     String?
  jobTitle        String?
  company         String?
  biodata         String?
  customFields    Json?
  activities      Activity[]
  callLogs        CallLog[]
  salestrailCalls SalestrailCall[]
  assignedAt      DateTime?
  assignedTo      User?       @relation(fields: [assignedToId], references: [id])
  workspace       Workspace?  @relation(fields: [workspaceId], references: [id])
  notes           Note[]
  tasks           Task[]
  deals           Deal[]
  automationLogs  AutomationLog[]
  assignmentHistories AssignmentHistory[]
  whatsappMessages WhatsAppMessage[]
  whatsappCampaignRecipients WhatsAppCampaignRecipient[]
  whatsappOptIn   Boolean   @default(false)
  whatsappOptInAt DateTime?
  emails          EmailLog[]

  lastActivityAt  DateTime?

  @@index([phoneNormalized])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedToId, status])
  @@index([assignedToId, createdAt])
  @@index([lastActivityAt])
  @@index([score])
  @@index([nextFollowUpAt])
}

model AutomationRule {
  id            String                @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean               @default(true)
  triggerType   String                // LEAD_CREATED | STATUS_CHANGED | NO_ACTIVITY | LEAD_ASSIGNED
  triggerConfig Json?                 // { status: "CONTACTED" } | { days: 1 }
  conditions    AutomationCondition[]
  actions       AutomationAction[]
  logs          AutomationLog[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model AutomationCondition {
  id       String         @id @default(uuid())
  ruleId   String
  field    String         // source | status | assignedTo
  operator String         // equals | not_equals | is_empty | is_not_empty
  value    String?
  rule     AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationAction {
  id     String         @id @default(uuid())
  ruleId String
  type   String         // ASSIGN_LEAD | CHANGE_STATUS | CREATE_TASK | CREATE_REMINDER | SEND_NOTIFICATION
  config Json
  order  Int            @default(0)
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
}

model AutomationLog {
  id        String         @id @default(uuid())
  ruleId    String
  leadId    String
  status    String         // SUCCESS | FAILED | SKIPPED
  details   Json?
  createdAt DateTime       @default(now())
  rule      AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  lead      Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([ruleId])
  @@index([ruleId, leadId, status])
  @@index([ruleId, createdAt])
}

model Note {
  id        String   @id @default(uuid())
  leadId    String?
  content   String
  createdAt DateTime @default(now())
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model AssignmentHistory {
  id                 String   @id @default(uuid())
  leadId             String
  employeeId         String
  previousEmployeeId String?
  reason             String?
  createdAt          DateTime @default(now())
  lead               Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  employee           User     @relation("HistoryEmployee", fields: [employeeId], references: [id])
  previousEmployee   User?    @relation("HistoryPrevEmployee", fields: [previousEmployeeId], references: [id])

  @@index([leadId])
  @@index([employeeId])
}

model Sprint {
  id        String       @id @default(uuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    SprintStatus @default(PLANNING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  tasks     Task[]
}

model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  leadId         String?
  assignedToId   String?
  dueDate        DateTime
  status         TaskStatus   @default(PENDING)
  kanbanStatus   KanbanStatus @default(TODO)
  priority       Priority     @default(MEDIUM)
  type           TaskType     @default(TASK)
  storyPoints    Int?
  estimatedHours Float?
  actualHours    Float?
  labels         String[]
  sprintId       String?
  orderIndex     Int          @default(0)
  completedAt    DateTime?
  updatedAt      DateTime     @default(now()) @updatedAt
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  lead           Lead?        @relation(fields: [leadId], references: [id])
  sprint         Sprint?      @relation(fields: [sprintId], references: [id])
  files          TaskFile[]
  comments       TaskComment[]

  @@index([leadId])
  @@index([sprintId])
  @@index([status])
  @@index([dueDate])
  @@index([assignedToId, status])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

model TaskFile {
  id        String   @id @default(uuid())
  taskId    String
  fileName  String
  fileUrl   String
  fileSize  Int
  mimeType  String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Integration {
  id            String           @id @default(uuid())
  platform      String           @unique
  isConnected   Boolean          @default(false)
  status        String           @default("DISCONNECTED") // CONNECTED | DISCONNECTED | ERROR
  lastSynced    DateTime?
  config        Json?
  accessToken   String?          // AES-256-GCM encrypted
  refreshToken  String?          // AES-256-GCM encrypted
  expiresAt     DateTime?
  errorMessage  String?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  logs          IntegrationLog[]
}

model IntegrationLog {
  id            String      @id @default(uuid())
  integrationId String
  type          String      // CONNECTED|DISCONNECTED|TOKEN_REFRESHED|SYNC_STARTED|SYNC_COMPLETED|SYNC_FAILED|WEBHOOK_RECEIVED|AUTH_FAILED
  message       String
  status        String      @default("INFO") // SUCCESS | ERROR | INFO
  metadata      Json?
  createdAt     DateTime    @default(now())
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, createdAt])
}

model Activity {
  id        String   @id @default(uuid())
  leadId    String?
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
  @@index([leadId, createdAt])
}

model Reminder {
  id        String   @id @default(uuid())
  leadId    String?
  taskId    String?
  userId    String
  remindAt  DateTime
  message     String
  isSent      Boolean  @default(false)
  dismissed   Boolean  @default(false)
  gcalEventId String?  // Google Calendar event id, when this reminder is mirrored to the user's calendar

  @@index([remindAt, isSent])
  @@index([userId])
  @@index([leadId])
  @@index([taskId])
}

model Commission {
  id        String   @id @default(uuid())
  userId    String
  leadId    String
  amount    Float
  createdAt DateTime @default(now())

  @@unique([userId, leadId])
}

model Permission {
  id       String @id @default(uuid())
  role     Role
  resource String
  action   String
}

model CallLog {
  id            String    @id @default(uuid())
  leadId        String
  userId        String?
  duration      Int       @default(0)
  callType      String    @default("OUTBOUND")
  createdAt     DateTime  @default(now())
  callStatus    String?
  recordingUrl  String?
  agentNumber   String?
  callDate      DateTime?
  greeterCallId String?
  transcription String?
  plainText     String?
  summary       String?
  tone          String?
  urgency       String?
  emotion       String?
  callCategory  String?
  sentiment     String?
  feedback      String?
  conclusion    String?
  isTranscribed Boolean   @default(false)
  transcribedAt DateTime?
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  device    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Workspace {
  id         String  @id @default(uuid())
  name       String
  logo       String?
  brandColor String?
  leads      Lead[]
  users      User[]
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Attendance {
  id        String           @id @default(uuid())
  userId    String
  date      DateTime         @default(now()) @db.Date
  checkIn   DateTime?
  checkOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  location  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Leave {
  id        String          @id @default(uuid())
  userId    String
  fromDate  DateTime        @db.Date
  toDate    DateTime        @db.Date
  totalDays Int
  reason    String
  leaveType String          @default("LEAVE")
  status    LeaveStatus     @default(PENDING)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvals LeaveApproval[]

  @@index([userId, status])
  @@index([userId, fromDate, toDate], map: "Leave_compoff_approved_idx")
}

model LeaveApproval {
  id         String         @id @default(uuid())
  leaveId    String
  approverId String
  status     ApprovalStatus @default(PENDING)
  comments   String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  approver   User           @relation("ApproverLeaves", fields: [approverId], references: [id], onDelete: Cascade)
  leave      Leave          @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  @@unique([leaveId, approverId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  EMPLOYEE
  TEAM_LEAD
  AGENT
}

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  GMAIL
  WEBSITE
  PHONE_CALL
  LINKEDIN
}

enum EnquiryType {
  PRODUCT
  WHITE_LABEL
  LMS
  SERVICES
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  CONVERTED
  LOST
  MERGED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
  WFH
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OnlineStatus {
  ONLINE
  OFFLINE
  BREAK
}

enum TaskStatus {
  PENDING
  COMPLETED
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AvailabilityStatus {
  ONLINE
  OFFLINE
  ON_LEAVE
}

enum TaskType {
  EPIC
  STORY
  TASK
  BUG
  SUBTASK
}

enum KanbanStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

model Deal {
  id                 String     @id @default(uuid())
  leadId             String
  title              String
  amount             Float      @default(0)
  stage              DealStage  @default(NEW)
  currency           String     @default("INR")
  createdById        String
  assignedEmployeeId String?
  closedAt           DateTime?
  invoiceId          String?
  notes              String?
  deletedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  lead               Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy          User       @relation("CreatedDeals", fields: [createdById], references: [id])
  assignedEmployee   User?      @relation("AssignedDeals", fields: [assignedEmployeeId], references: [id])
  invoices           Invoice[]  @relation("DealInvoices")

  @@index([leadId])
  @@index([createdById])
  @@index([assignedEmployeeId])
  @@index([stage])
  @@index([deletedAt])
  @@index([invoiceId])
}

enum DealStage {
  NEW
  NEGOTIATION
  WON
  LOST
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNumber String        @unique
  invoiceType   InvoiceType   @default(PROFORMA)
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?
  clientGstin   String?
  subtotal      Float
  cgst          Float         @default(0)
  sgst          Float         @default(0)
  igst          Float         @default(0)
  total         Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  notes         String?
  emailSentAt   DateTime?
  emailSentTo   String?
  createdById   String
  dealId        String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  items         InvoiceItem[]
  payments      PaymentEntry[]
  createdBy     User          @relation("CreatedInvoices", fields: [createdById], references: [id])
  deal          Deal?         @relation("DealInvoices", fields: [dealId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([deletedAt])
}

model InvoiceItem {
  id           String  @id @default(uuid())
  invoiceId    String
  description  String
  price        Float
  quantity     Float   @default(1)
  taxRate      Float   @default(18)
  taxableValue Float
  amount       Float
  invoice      Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PaymentEntry {
  id          String      @id @default(uuid())
  invoiceId   String
  amount      Float
  type        PaymentType @default(CREDIT)
  description String?
  paymentDate DateTime    @default(now())
  createdAt   DateTime    @default(now())
  invoice     Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

enum InvoiceType {
  PROFORMA
  TAX_INVOICE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentType {
  CREDIT
  DEBIT
}

model InvoiceCounter {
  prefix       String @id
  currentValue Int    @default(0)
}

model CompanySettings {
  id            String   @id @default(uuid())
  companyName   String   @default("HEXITE TECHNOLOGIES PRIVATE LIMITED")
  shortName     String   @default("HXZ")
  gstin         String   @default("33AAHCH4159D1ZT")
  address       String   @default("No 98, Varadharajan Street Kaladipet")
  city          String   @default("Chennai")
  state         String   @default("Tamil Nadu")
  pincode       String   @default("600019")
  phone         String   @default("+91 9994081905, 9566999018")
  email         String   @default("praveen@hexitetechnologies.com")
  website       String   @default("https://hexitetechnologies.com/")
  placeOfSupply String   @default("33-Tamil Nadu")
  bankName      String   @default("Axis Bank")
  accountNo     String   @default("924020046598227")
  ifsc          String   @default("UTIB0001619")
  branch        String   @default("Thiruvottriyur")
  defaultTaxRate Float   @default(18)
  defaultNotes  String   @default("")
  smtpHost      String?
  smtpPort      Int?
  smtpUser      String?
  smtpPass      String?
  smtpFrom      String?
  smtpSecure      Boolean  @default(false)
  slaWarningDays  Int      @default(3)
  slaBreachDays   Int      @default(7)
  assistantEnabled         Boolean @default(true)
  assistantRateLimitPerMin Int     @default(30)
  assistantMaxHistoryTurns Int     @default(6)
  // Attendance check-in window (IST). Enforced only when enabled; times are "HH:MM".
  attendanceDeadlineEnabled Boolean @default(true)
  attendanceDeadlineWeekday String  @default("11:50")
  attendanceDeadlineSunday  String  @default("12:30")
  updatedAt       DateTime @updatedAt
}

model AssistantRequestLog {
  id          String   @id @default(uuid())
  userId      String
  status      String   // SUCCESS | ERROR | RATE_LIMITED | DISABLED
  totalTokens Int      @default(0)
  primaryTool String?
  latencyMs   Int      @default(0)
  inputMode   String   @default("chat")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model EmailTemplate {
  id          String   @id @default(uuid())
  name        String
  subject     String
  body        String
  isShared    Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model EmailLog {
  id            String    @id @default(uuid())
  leadId        String
  subject       String
  body          String
  toEmail       String
  sentById      String
  openedAt      DateTime?
  clickCount    Int       @default(0)
  lastClickedAt DateTime?
  createdAt     DateTime  @default(now())
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sentBy        User      @relation("SentEmails", fields: [sentById], references: [id])

  @@index([leadId])
}

model CustomFieldDef {
  id        String   @id @default(uuid())
  name      String
  fieldKey  String   @unique
  type      String   @default("TEXT")
  options   Json?
  required  Boolean  @default(false)
  visible   Boolean  @default(true)
  isSystem  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model WhatsAppMessage {
  id              String    @id @default(uuid())
  leadId          String
  userId          String?
  phone           String
  direction       String    @default("OUTBOUND")  // OUTBOUND | INBOUND
  templateName    String?
  messageBody     String
  status          String    @default("SENT")       // SENT | DELIVERED | READ | REPLIED | FAILED
  watiMessageId   String?
  replyText       String?
  providerPayload Json?
  sentAt          DateTime  @default(now())
  deliveredAt     DateTime?
  readAt          DateTime?
  repliedAt       DateTime?
  createdAt       DateTime  @default(now())
  lead              Lead      @relation(fields: [leadId], references: [id])
  user              User?     @relation(fields: [userId], references: [id])
  campaignRecipient WhatsAppCampaignRecipient?

  @@index([leadId])
  @@index([watiMessageId])
}

model WhatsAppCampaign {
  id             String    @id @default(uuid())
  name           String
  templateName   String
  parameters     Json
  status         String    @default("DRAFT")
  totalCount     Int       @default(0)
  sentCount      Int       @default(0)
  deliveredCount Int       @default(0)
  readCount      Int       @default(0)
  repliedCount   Int       @default(0)
  failedCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  createdById    String
  createdBy      User      @relation(fields: [createdById], references: [id])
  recipients     WhatsAppCampaignRecipient[]

  @@index([createdById])
}

model WhatsAppCampaignRecipient {
  id         String    @id @default(uuid())
  campaignId String
  leadId     String
  phone      String
  status     String    @default("QUEUED")
  messageId  String?   @unique
  failReason String?
  sentAt     DateTime?
  repliedAt  DateTime?
  replyText  String?
  campaign   WhatsAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead       Lead             @relation(fields: [leadId], references: [id])
  message    WhatsAppMessage? @relation(fields: [messageId], references: [id])

  @@index([campaignId])
  @@index([leadId])
  @@index([phone])
}

model WhatsAppAutoReply {
  id            String   @id @default(uuid())
  name          String
  active        Boolean  @default(true)
  triggerType   String
  keyword       String?
  timeoutHours  Int?
  replyTemplate String
  replyParams   Json     @default("[]")
  createdAt     DateTime @default(now())
  createdById   String
  createdBy     User     @relation(fields: [createdById], references: [id])
}

model SalestrailCall {
  id            String    @id @default(uuid())
  salestrailId  String?   @unique
  direction     String    @default("outgoing")
  status        String?
  duration      Int       @default(0)
  fromNumber    String?
  toNumber      String?
  agentName     String?
  agentEmail    String?
  contactName   String?
  contactPhone  String?
  recordingUrl  String?
  notes         String?
  rawPayload    Json?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])

  @@index([startedAt])
  @@index([agentEmail])
  @@index([leadId])
}

model ImportJob {
  id          String   @id @default(uuid())
  status      String   @default("queued")   // queued | processing | done | failed
  stage       String   @default("queued")   // queued | parsing | deduping | inserting | assigning | complete
  progress    Int      @default(0)           // 0-100
  total       Int      @default(0)
  imported    Int      @default(0)
  duplicates  Int      @default(0)
  skipped     Int      @default(0)
  failed      Int      @default(0)
  assigned    Int      @default(0)
  errors      Json     @default("[]")
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([createdById])
}

model ManagerNote {
  id        String   @id @default(uuid())
  authorId  String
  subjectId String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("NoteAuthor",  fields: [authorId],  references: [id], onDelete: Cascade)
  subject   User     @relation("NoteSubject", fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
  @@index([authorId])
}
