# ─── Backend environment template ──────────────────────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored.
# On hosted deployments (Render/Railway/etc.), set these in the provider dashboard.

# Core
DATABASE_URL=
JWT_SECRET=
PORT=5001
FRONTEND_URL=

# Auth / video (Stream)
STREAM_API_KEY=
STREAM_SECRET_KEY=

# AI / LLM
OPENAI_API_KEY=
LLM_PROVIDER=
OPENAI_MODEL=
ASSISTANT_ENABLED=
ASSISTANT_RATE_LIMIT=
ASSISTANT_MAX_HISTORY_TURNS=

# Lead enrichment / search
SERPER_API_KEY=

# Google OAuth (Calendar / Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Meta / Facebook lead ads
META_APP_ID=
META_APP_SECRET=

# WhatsApp greeter
GREETER_USER_ID=
GREETER_NUMBER=
GREETER_API_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=

# Telephony (Salestrail)
SALESTRAIL_USER=
SALESTRAIL_PASS=

# Misc
ENCRYPTION_KEY=

# ─── File storage (Cloudinary) ──────────────────────────────────────────────────
# REQUIRED for persistent uploads (resumes, recordings). Without these the backend
# falls back to local disk, which is ephemeral on most hosts (files vanish on
# redeploy) and produces relative URLs that break cross-origin links.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
