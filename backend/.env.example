# ─── Backend environment template ──────────────────────────────────────────────
# Copy to `.env` and fill in real values. `.env` is gitignored.
# On hosted deployments (Render/Railway/etc.), set these in the provider dashboard.

# Core
DATABASE_URL=
JWT_SECRET=
PORT=5001
FRONTEND_URL=

# Auth / video (Stream)
STREAM_API_KEY=
STREAM_SECRET_KEY=

# AI / LLM
OPENAI_API_KEY=
LLM_PROVIDER=
OPENAI_MODEL=
ASSISTANT_ENABLED=
ASSISTANT_RATE_LIMIT=
ASSISTANT_MAX_HISTORY_TURNS=

# Lead enrichment / search
SERPER_API_KEY=


# Meta / Facebook lead ads
META_APP_ID=
META_APP_SECRET=

# WhatsApp greeter
GREETER_USER_ID=
GREETER_NUMBER=
GREETER_API_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=

# Telephony (Salestrail)
SALESTRAIL_USER=
SALESTRAIL_PASS=

# Misc
ENCRYPTION_KEY=

# ─── File storage (Bunny.net) ───────────────────────────────────────────────────
# REQUIRED for persistent uploads (profile photos, resumes, task files, documents).
# Without these the backend falls back to local disk, which is ephemeral on most
# hosts (files vanish on redeploy) and produces relative URLs that break
# cross-origin links.
#   - Create a Storage Zone and copy its name + password (write access key).
#   - Attach a Pull Zone (CDN) to it and copy its hostname (e.g. yourzone.b-cdn.net).
#   - REGION is the storage region prefix (e.g. "sg", "ny"); leave empty for the
#     default (DE/Falkenstein) region.
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_ACCESS_KEY=
BUNNY_STORAGE_REGION=
BUNNY_PULL_ZONE_HOST=
# Enable "Token Authentication" on the Pull Zone and paste its security key here to
# make gated documents/resumes/recordings serve as short-lived signed URLs. If left
# blank, CDN URLs are public (but use unguessable random filenames).
BUNNY_TOKEN_SECURITY_KEY=
